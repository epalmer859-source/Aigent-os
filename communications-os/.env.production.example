# Production environment variables for Vercel
# Copy these keys into your Vercel project → Settings → Environment Variables
# Never commit actual secret values to version control.

# ── Database (Neon, Supabase, Railway, etc.) ─────────────────
DATABASE_URL="postgresql://user:password@host:5432/aigent-os?sslmode=require"

# ── NextAuth ─────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET="replace-with-64-char-random-string"

# Your production domain (no trailing slash) — NextAuth v5 uses AUTH_URL
AUTH_URL="https://your-app.vercel.app"

# ── Anthropic (AI responses) ─────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# ── Twilio (SMS / voice) ──────────────────────────────────────
# https://console.twilio.com/
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token"
# E.164 format
TWILIO_PHONE_NUMBER="+15550001234"

# ── Email provider (pick one) ────────────────────────────────
# SENDGRID_API_KEY="SG...."
# RESEND_API_KEY="re_..."

# ── Google Calendar OAuth ────────────────────────────────────
# https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
# Must match the redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI="https://your-app.vercel.app/api/auth/callback/google"

# ── Node environment (Vercel sets this automatically) ────────
NODE_ENV="production"
