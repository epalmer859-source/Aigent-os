model technicians {
  id                        String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id               String                  @db.Uuid
  name                      String
  home_base_lat             Float
  home_base_lng             Float
  home_base_address         String
  working_hours_start       String                  @default("08:00")
  working_hours_end         String                  @default("17:00")
  lunch_start               String                  @default("12:00")
  lunch_end                 String                  @default("12:30")
  overtime_cap_minutes      Int                     @default(0)
  is_active                 Boolean                 @default(true)
  location_services_enabled Boolean                 @default(false)
  created_at                DateTime                @default(now()) @db.Timestamptz(6)
  updated_at                DateTime                @default(now()) @db.Timestamptz(6)
  businesses                businesses              @relation(fields: [business_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  skill_tags                technician_skill_tags[]
