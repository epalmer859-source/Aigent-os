  customer_phone          String
  original_technician_id  String                 @db.Uuid
  original_date           DateTime               @db.Date
  original_queue_position Int
  target_technician_id    String                 @db.Uuid
  target_date             DateTime               @db.Date
  new_queue_position      Int
  total_cost_minutes      Int
  time_preference         TimePreference
  original_window         String
  new_window              String
  status                  PullForwardOfferStatus @default(active)
  expires_at              DateTime               @db.Timestamptz(6)
  created_at              DateTime               @default(now()) @db.Timestamptz(6)
  updated_at              DateTime               @default(now()) @db.Timestamptz(6)
  scheduling_jobs         scheduling_jobs        @relation(fields: [scheduling_job_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([scheduling_job_id, status], map: "pull_forward_offers_job_idx")
  @@index([gap_id, status], map: "pull_forward_offers_gap_idx")
}

model transfer_events {
  id                            String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  scheduling_job_id             String           @db.Uuid
  from_technician_id            String           @db.Uuid
  to_technician_id              String           @db.Uuid
  from_date                     DateTime         @db.Date
  to_date                       DateTime         @db.Date
  from_queue_position           Int
  to_queue_position             Int
  approval_type                 TransferApproval
  net_drive_time_saving_minutes Int
  created_at                    DateTime         @default(now()) @db.Timestamptz(6)
  scheduling_jobs               scheduling_jobs  @relation("transfer_events_from_job", fields: [scheduling_job_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([scheduling_job_id], map: "transfer_events_job_idx")
  @@index([from_technician_id, created_at], map: "transfer_events_from_tech_idx")
}

model scheduling_mode_events {
  id          String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id String         @db.Uuid
  from_mode   SchedulingMode
  to_mode     SchedulingMode
  user_id     String
  timestamp   DateTime       @db.Timestamptz(6)
  created_at  DateTime       @default(now()) @db.Timestamptz(6)
  businesses  businesses     @relation(fields: [business_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([business_id, timestamp], map: "scheduling_mode_events_biz_idx")
}

model starting_my_day_log {
  id            String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  technician_id String      @db.Uuid
  date          DateTime    @db.Date
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  technicians   technicians @relation(fields: [technician_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([technician_id, date], map: "starting_my_day_log_tech_date_unique")
}
