  @@index([business_id], map: "service_types_business_idx")
}

model scheduling_jobs {
  id                         String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id                String                @db.Uuid
  technician_id              String                @db.Uuid
  customer_id                String                @db.Uuid
  appointment_id             String?               @db.Uuid
  service_type_id            String                @db.Uuid
  status                     SchedulingJobStatus   @default(NOT_STARTED)
  queue_position             Int
  scheduled_date             DateTime              @db.Date
  time_preference            TimePreference        @default(NO_PREFERENCE)
  estimated_duration_minutes Int
  actual_duration_minutes    Int?
